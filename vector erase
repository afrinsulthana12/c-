#include <cmath>
#include <cstdio>
#include <vector>
#include <iostream>
#include <algorithm>
using namespace std;

int main() {
    int n;
    cin >> n;

    vector<int> v(n);
    for (int i = 0; i < n; i++) {
        cin >> v[i];
    }

    // Query 1: Erase element at a specific position (1-based)
    int x;
    cin >> x;
    // Convert 1-based to 0-based by subtracting 1
    v.erase(v.begin() + (x - 1));

    // Query 2: Erase elements in a range [a, b) (1-based)
    int a, b;
    cin >> a >> b;
    // v.begin() + (a-1) is the start (inclusive)
    // v.begin() + (b-1) is the end (exclusive)
    v.erase(v.begin() + (a - 1), v.begin() + (b - 1));

    // Output the final size
    cout << v.size() << endl;

    // Output the remaining elements
    for (int i = 0; i < v.size(); i++) {
        cout << v[i] << (i == v.size() - 1 ? "" : " ");
    }

    return 0;
}
