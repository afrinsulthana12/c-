#include <iostream>
#include <set>
#include <algorithm>

using namespace std;

int main() {
    // Speed up I/O for large query sets
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int q;
    if (!(cin >> q)) return 0;

    set<int> s;
    while (q--) {
        int type, x;
        cin >> type >> x;

        if (type == 1) {
            // Add element x to the set
            s.insert(x);
        } else if (type == 2) {
            // Delete element x from the set (does nothing if not present)
            s.erase(x);
        } else if (type == 3) {
            // Check if x is present
            if (s.find(x) != s.end()) {
                cout << "Yes" << "\n";
            } else {
                cout << "No" << "\n";
            }
        }
    }

    return 0;
}



