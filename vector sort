#include <cmath>
#include <cstdio>
#include <vector>
#include <iostream>
#include <algorithm>
using namespace std;

int main() {
    int n;
    // Read the number of integers
    if (!(cin >> n)) return 0;

    // Initialize the vector
    vector<int> v;

    // Read n integers and push them into the vector
    for (int i = 0; i < n; i++) {
        int temp;
        cin >> temp;
        v.push_back(temp);
    }

    // Sort the vector from the beginning to the end
    // std::sort uses a highly optimized QuickSort/IntroSort algorithm
    sort(v.begin(), v.end());

    // Print the sorted integers separated by spaces
    for (int i = 0; i < v.size(); i++) {
        cout << v[i] << " ";
    }

    return 0;
}

